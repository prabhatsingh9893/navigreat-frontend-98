{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "unsafe-none"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/__/auth/:path*",
      "destination": "https://edumentor-auth-37712.firebaseapp.com/__/auth/:path*"
    },
    {
      "source": "/((?!api|__/auth|static|assets|.*\\..*).*)$",
      "destination": "/index.html"
    }
  ],
  "git": {
    "deploymentEnabled": {
      "main": true,
      "gh-pages": false
    }
  }
}