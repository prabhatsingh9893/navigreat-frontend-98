# Copy this file to .env and fill in your own values.
# Do NOT commit the real .env — it is gitignored.

# Zoom Meeting SDK client id (used for live sessions)
VITE_ZOOM_CLIENT_ID=your_zoom_client_id_here

# Firebase Cloud Messaging VAPID key (used for web push notifications)
VITE_FIREBASE_VAPID_KEY=your_firebase_vapid_key_here
